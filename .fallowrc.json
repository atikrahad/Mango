{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    ".next/**",
    ".turbo/**",
    "packages/eslint-config/**",
    "packages/typescript-config/**"
  ],
  "rules": {
    "unused-files": "warn",
    "unused-exports": "warn"
  }
}
