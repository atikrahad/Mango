              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"replace-with-actual-product-id\",\n  \"sku\": \"MNG-AMP-05K-ORG\",\n  \"weightKg\": 5.0,\n  \"boxCount\": 1,\n  \"price\": 1200.0,\n  \"discount\": 0.0\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/catalog/variants",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
