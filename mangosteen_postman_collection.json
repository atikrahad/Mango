{
  "info": {
    "_postman_id": "c7a8d56b-67a3-4874-9844-93ad982b6e14",
    "name": "Mangosteen API Testing Suite",
    "description": "Comprehensive Postman collection for Mangosteen Monorepo API testing. Features full support for User Session Actions, E-Commerce Catalog, Affiliate Partner wallet tracking, Admin Orders ledger, and Rider OTP COD delivery logistics.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "your_jwt_access_token_here",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Authentication Module",
      "description": "User registration, login session tokens, refresh tokens, active session context, and logout endpoints.",
      "item": [
        {
          "name": "User Registration",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"affiliate2@mangosteen.com\",\n  \"password\": \"password123\",\n  \"fullName\": \"Affiliate Abul\",\n  \"role\": \"AFFILIATE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Registers a new user inside the system. Acceptable roles include: 'CUSTOMER', 'AFFILIATE', 'ADMIN', 'DELIVERY_AGENT', or 'SUPER_ADMIN'."
          }
        },
        {
          "name": "User Session Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.data && jsonData.data.accessToken) {",
                  "    pm.collectionVariables.set(\"accessToken\", jsonData.data.accessToken);",
                  "    console.log(\"Saved accessToken variable automatically!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"superadmin@mangosteen.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Authenticates user credentials and returns a Bearer JWT access token, setting a secure httpOnly cookie with the refresh token."
          }
        },
        {
          "name": "Token Refresh Rotation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            },
            "description": "Rotates session identifiers by exchanging the httpOnly refresh cookie for a brand new brief JWT access token."
          }
        },
        {
          "name": "Active Session Context (me)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            },
            "description": "Retrieves the active user profile information decoded directly from the Bearer JWT token."
          }
        },
        {
          "name": "Sign Out & Terminate Session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            },
            "description": "Clears all active session authorization cookies from the client browser."
          }
        }
      ]
    },
    {
      "name": "2. E-Commerce Catalog Module",
