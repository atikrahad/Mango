                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryId\": \"replace-with-actual-category-id\",\n  \"name\": \"Amrapali Premium Harvest\",\n  \"slug\": \"amrapali-premium-harvest\",\n  \"description\": \"Sweet, aromatic, highly flavorful premium Amrapali mangoes from Rajshahi orchards.\",\n  \"sweetness\": 5,\n  \"isOrganic\": true,\n  \"originDistrict\": \"Rajshahi\",\n  \"imageUrl\": \"[\\\"https://images.unsplash.com/photo-1553279768-865429fa0078\\\"]\",\n  \"seoTitle\": \"Buy Amrapali Premium Harvest Online\",\n  \"seoDesc\": \"Experience organic Amrapali mangoes sent straight to your home from local orchards.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/catalog/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "catalog",
                "products"
              ]
            },
            "description": "Creates a new catalog product profile. Requires Admin/SuperAdmin JWT session authorization."
          }
        },
        {
          "name": "Create Product Variant (Admin)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
