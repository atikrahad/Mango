{
  "name": "mangosteen-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise Mango E-Commerce & Affiliate Platform",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "npm run generate --workspace=database",
    "db:migrate": "npm run migrate --workspace=database",
    "db:seed": "npm run seed --workspace=database"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "turbo": "^1.13.0",
    "prettier": "^3.2.5"
  }
}
