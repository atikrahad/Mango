{
  "name": "mangosteen-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise Mango E-Commerce & Affiliate Platform",
  "scripts": {
    "dev": "turbo run dev",
    "start": "turbo run start:prod",
    "postinstall": "npm run db:generate",
    "build": "npm run db:generate && npx prisma db push --schema=packages/database/prisma/schema.prisma && turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "npm run generate --workspace=@mangosteen/database",
    "db:migrate": "npm run migrate --workspace=@mangosteen/database",
    "db:seed": "npm run seed --workspace=@mangosteen/database",
    "fallow": "npx -y fallow",
    "fallow:dupes": "npx -y fallow dupes"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "turbo": "^1.13.0",
    "prettier": "^3.2.5"
  }
}
